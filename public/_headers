/* 
  Cache-Control: no-cache, must-revalidate, max-age=0
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), camera=(), microphone=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https:; frame-ancestors 'self'

/*.js
  Cache-Control: immutable, max-age=31536000
  Content-Type: application/javascript

/*.css 
  Cache-Control: immutable, max-age=31536000
  Content-Type: text/css

/images/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
  
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/sw.js 
  Cache-Control: no-cache, must-revalidate, max-age=0
  Service-Worker-Allowed: /

# Critical: Set proper caching for HTML files to allow updates
/*.html
  Cache-Control: no-cache, must-revalidate, max-age=0
  
# Index files must not be cached to ensure indexing updates
/index.html
  Cache-Control: no-cache, must-revalidate, max-age=0
  X-Robots-Tag: index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1

# Sitemaps and robots.txt must not be cached
/sitemap.xml
  Cache-Control: no-cache, must-revalidate, max-age=0

/robots.txt
  Cache-Control: no-cache, must-revalidate, max-age=0

# Product and category pages - allow conditional caching
/product/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
  X-Robots-Tag: index, follow

/category/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
  X-Robots-Tag: index, follow

# Search pages should not be cached
/search*
  Cache-Control: no-cache, must-revalidate, max-age=0
  X-Robots-Tag: index, follow

# Admin and private pages should not be indexed
/account/*
  X-Robots-Tag: noindex, follow

/dashboard*
  X-Robots-Tag: noindex, follow

/api/*
  X-Robots-Tag: noindex, nofollow
