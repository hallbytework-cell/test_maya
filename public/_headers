/* 
  Cache-Control: no-cache, must-revalidate, max-age=0
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), camera=(), microphone=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https:; frame-ancestors 'self'
  X-UA-Compatible: IE=edge
  Accept-CH: DPR, Viewport-Width, Width
  Accept-CH-Lifetime: 86400

/*.js
  Cache-Control: public, immutable, max-age=31536000
  Content-Type: application/javascript
  Content-Encoding: gzip
  Vary: Accept-Encoding

/*.css 
  Cache-Control: public, immutable, max-age=31536000
  Content-Type: text/css
  Content-Encoding: gzip
  Vary: Accept-Encoding

/images/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=604800
  Vary: Accept-Encoding
  
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding

/sw.js 
  Cache-Control: no-cache, must-revalidate, max-age=0
  Service-Worker-Allowed: /

/*.html
  Cache-Control: no-cache, must-revalidate, max-age=0
  
/index.html
  Cache-Control: no-cache, must-revalidate, max-age=0
  X-Robots-Tag: index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1

/sitemap.xml
  Cache-Control: no-cache, must-revalidate, max-age=0

/robots.txt
  Cache-Control: no-cache, must-revalidate, max-age=0

/product/*
  Cache-Control: public, max-age=7200, stale-while-revalidate=86400
  X-Robots-Tag: index, follow
  Vary: Accept-Encoding

/category/*
  Cache-Control: public, max-age=7200, stale-while-revalidate=86400
  X-Robots-Tag: index, follow
  Vary: Accept-Encoding

/* Mobile-optimized: Serve compressed assets to mobile browsers */
/*.br
  Cache-Control: public, immutable, max-age=31536000
  Content-Encoding: br
  Content-Type: application/javascript;charset=UTF-8; Vary: Accept-Encoding

/*.gz
  Cache-Control: public, immutable, max-age=31536000
  Content-Encoding: gzip
  Content-Type: application/javascript;charset=UTF-8; Vary: Accept-Encoding
  X-Robots-Tag: index, follow

# Search pages should not be cached
/search*
  Cache-Control: no-cache, must-revalidate, max-age=0
  X-Robots-Tag: index, follow

# Admin and private pages should not be indexed
/account/*
  X-Robots-Tag: noindex, follow

/dashboard*
  X-Robots-Tag: noindex, follow

/api/*
  X-Robots-Tag: noindex, nofollow
